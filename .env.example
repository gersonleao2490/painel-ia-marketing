# Variáveis de ambiente da NUVEM (configure no Vercel → Settings → Environment Variables)
# NÃO comite o arquivo .env de verdade — só este exemplo.

# Banco de dados Neon (Postgres). Pegue em neon.tech → seu projeto → Connection string.
DATABASE_URL=postgresql://USUARIO:SENHA@HOST.neon.tech/NOMEDB?sslmode=require

# Segredo para assinar a sessão (invente uma frase longa e aleatória).
SESSION_SECRET=troque-por-uma-frase-bem-grande-aleatoria-123

# Código de convite para o 1º cadastro (você escolhe).
INVITE_CODE=ESCOLHA-UM-CODIGO

# Chave do Google Gemini (a mesma que já usamos).
GEMINI_KEY=sua-chave-do-gemini
GEMINI_MODEL=gemini-2.5-flash

# API de dados do Instagram (RapidAPI) — opcional no começo; pode colar depois pelo ⚙️.
RAPIDAPI_KEY=
RAPIDAPI_HOST=instagram-scraper-api2.p.rapidapi.com
RAPIDAPI_PATH=/v1/info?username_or_id_or_url={handle}
